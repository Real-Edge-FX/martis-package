{
    "name": "martis/martis",
    "description": "Martis \u2014 React-first Laravel admin engine with full-stack resources, lenses, metrics, and a token-driven design system.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "endroid/qr-code": "^5.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0",
        "dedoc/scramble": "^0.12",
        "orchestra/testbench": "^10.11",
        "laravel/scout": "^11.1",
        "laravel/socialite": "^5.26"
    },
    "autoload": {
        "psr-4": {
            "Martis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Martis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Martis\\MartisServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "laravel/scout": "Required for Scout search integration (auto-detected when model uses Searchable trait)",
        "laravel/socialite": "Required when using martis:sso (any provider)",
        "socialiteproviders/microsoft": "Required when using martis:sso azure",
        "spatie/laravel-permission": "Auto-detected when present; SsoManager picks the SpatieAdapter for role sync"
    }
}

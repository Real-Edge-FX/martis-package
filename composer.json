{
    "name": "martis/martis",
    "description": "Martis \u2014 Laravel Admin Engine. Feature parity with Laravel Nova.",
    "type": "library",
    "license": "proprietary",
    "version": "0.1.0-dev",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.0",
        "dedoc/scramble": "^0.12",
        "orchestra/testbench": "^10.11"
    },
    "autoload": {
        "psr-4": {
            "Martis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Martis\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Martis\\MartisServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
